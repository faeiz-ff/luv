
typ Fraction[T] {
    numer: int
    denom: int
}

fun Fraction::new(numer: int, denom: int) -> Fraction? {
    if denom == 0 {
        ret nil
    } else {
        ret Fraction { numer, denom }
    }
}

fun Fraction.toFlt() -> flt {
    ret numer * 1.0 / denom
}

fun main() {
    var f = Fraction::new(1, 2)
}
